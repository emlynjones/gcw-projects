# --- Core ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=changeme
AUTH_URL=https://projects.cambrianweb.dev
DATABASE_URL=file:./dev.db

# --- Microsoft Entra ID (GCW staff SSO) ---
AUTH_MICROSOFT_ENTRA_ID_ID=<application-client-id>
AUTH_MICROSOFT_ENTRA_ID_SECRET=<client-secret-value>
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
# Optional: restrict SSO to one email domain
ALLOWED_EMAIL_DOMAIN=cambrianweb.com

# --- Admin credentials login (seeded on container start) ---
ADMIN_EMAIL=emlyn@cambrianweb.com
ADMIN_NAME=Emlyn Jones
ADMIN_PASSWORD=changeme

# --- Xero (optional until connected) ---
# Create a "Web app" at https://developer.xero.com/app/manage
# Redirect URI: https://projects.cambrianweb.dev/api/xero/callback
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
# Sales account code for invoice line items (Xero default chart: 200 = Sales)
XERO_SALES_ACCOUNT_CODE=200

# --- MCP API ---
# Generate with: openssl rand -hex 32
MCP_API_KEY=changeme
