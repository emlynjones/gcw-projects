generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Client {
  id            String    @id @default(cuid())
  name          String
  contactName   String?
  email         String?
  phone         String?
  xeroContactId String? // Xero sync deferred — field reserved
  projects      Project[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Project {
  id          String       @id @default(cuid())
  title       String
  clientId    String
  client      Client       @relation(fields: [clientId], references: [id])
  type        String       @default("PROJECT") // PROJECT | ADHOC — drives stage track + invoicing UI
  stage       String       @default("ENQUIRY") // per-type stage track; lifecycle derived (see lib/status.ts)
  archived    Boolean      @default(false) // orthogonal to stage — anything can be archived
  totalValue  Float        @default(0) // ex-VAT
  depositPct  Float        @default(30) // deposit % of total (full projects)
  startDate   DateTime? // month-level precision is fine — stored as 1st of month from bulk add
  targetDate  DateTime? // expected finish
  completedDate DateTime? // actual completion — auto-set when a project goes LIVE; used for duration reporting
  hoursQuoted Float? // ad-hoc: hours quoted
  hoursDone   Float? // ad-hoc: hours actually done
  description String? // free-text overview / scope
  briefText   String? // tender / brief as free text (or use a BRIEF file)
  siteStructure String? // plain-text proposed site structure / sitemap
  structureApproved Boolean @default(false) // client has signed off the structure
  proposalUrl String?
  invoices    Invoice[]
  notes       Note[]
  attachments Attachment[]
  devSites    DevSite[]
  files       ProjectFile[]
  services    ProjectService[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// Repeatable dev/staging URLs for a project; one may be marked approved.
model DevSite {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url       String
  label     String?
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
}

// Uploaded documents stored on the data volume (proposal PDF, brief, etc.).
model ProjectFile {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  kind      String   // PROPOSAL | BRIEF | OTHER
  filename  String   // original filename shown to the user
  path      String   // path relative to the uploads dir
  mime      String?
  size      Int?
  createdAt DateTime @default(now())
}

// Services attached to a project — the basis for the final invoice.
model ProjectService {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  serviceId String? // optional link back to the price-list Service
  name      String
  unit      String   @default("one-off")
  price     Float    @default(0) // ex-VAT unit price
  quantity  Float    @default(1)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

// App-wide key/value settings. Secret values (AI API keys) are stored encrypted.
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Invoice {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  amount        Float // ex-VAT
  reference     String
  kind          String?  // DEPOSIT | INTERIM | FINAL | null (untagged/other)
  date          DateTime @default(now())
  paid          Boolean  @default(false)
  xeroInvoiceId String? // linked Xero invoice (InvoiceID)
  xeroNumber    String? // Xero invoice number (INV-xxxx)
  xeroStatus    String? // DRAFT | SUBMITTED | AUTHORISED | PAID | VOIDED
  xeroSynced    Boolean  @default(false)
  createdAt     DateTime @default(now())
}

// Single-row table: the app-wide Xero org connection (GCW's own books)
model XeroConnection {
  id           String   @id @default("xero")
  tenantId     String
  tenantName   String
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  scope        String
  updatedAt    DateTime @updatedAt
}

model Service {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  price       Float // ex-VAT
  unit        String  @default("one-off") // one-off | month | year | hour | session | day | half-day
  category    String
  active      Boolean @default(true)
  sortOrder   Int     @default(0)
}

model Note {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author    String
  body      String
  timestamp DateTime @default(now()) // display date — editable (backdate a call, etc.)
  createdAt DateTime @default(now())
}

model Attachment {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  label     String
  url       String // external link only in v1 (SharePoint etc.)
  createdAt DateTime @default(now())
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  role         String   @default("staff") // admin | staff (identical permissions in v1)
  provider     String // entra | credentials
  passwordHash String?
  createdAt    DateTime @default(now())
}
